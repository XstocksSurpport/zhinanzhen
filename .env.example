# Copy to project root .env and/or scripts/.env (both are loaded).

# Required on Sepolia / mainnet (0x + 64 hex, no quotes)
PRIVATE_KEY=

# Strongly recommended on mainnet (avoid public RPC rate limits)
# MAINNET_RPC_URL=https://eth-mainnet.g.alchemy.com/v2/YOUR_KEY

# Optional: custom RPC (defaults shown in hardhat.config.js)
# SEPOLIA_RPC_URL=https://rpc.sepolia.org

# Optional: override Uniswap V2 Router02 (Sepolia has a default in scripts/deploy.js)
# UNISWAP_V2_ROUTER=

# Optional: 分红代币地址；不设则默认 0xf280B16EF293D8e534e370794ef26bF312694126（主网/Sepolia 一致）
# REWARD_TOKEN=

# Optional: 管理员与 Ownable owner；不设则主网/Sepolia 均默认 0x...dEaD（放弃管理权限）
# ADMIN=

# Optional: Chainlink ETH/USD; if unset on Sepolia, script uses Sepolia feed address
# CHAINLINK_ETH_USD=

# Etherscan（验证 / getabi；https://docs.etherscan.io/）
# ETHERSCAN_API_KEY=
# 若 api.etherscan.io 超时，填本机 HTTP 代理（与 Clash / v2ray 端口一致）：
# ETHERSCAN_HTTP_PROXY=http://127.0.0.1:7890
