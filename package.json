{
  "name": "babyasteroid",
  "version": "1.0.0",
  "license": "MIT",
  "private": true,
  "main": "electron/main.cjs",
  "scripts": {
    "compile": "hardhat compile",
    "test": "hardhat test",
    "deploy:local": "hardhat run scripts/deploy.js",
    "deploy:mainnet": "hardhat run scripts/deploy.js --network mainnet",
    "deploy:sepolia": "hardhat run scripts/deploy.js --network sepolia",
    "verify:mainnet": "hardhat run scripts/verify-mainnet.js --network mainnet",
    "verify:mainnet:a": "powershell -NoProfile -ExecutionPolicy Bypass -File ./scripts/verify-method-a.ps1 -IncludeHardhat",
    "verify:etherscan-api": "hardhat run scripts/etherscan-verify-api.js",
    "verify:a": "powershell -NoProfile -ExecutionPolicy Bypass -File ./scripts/verify-method-a.ps1",
    "verify:etherscan-api:proxy": "powershell -NoProfile -ExecutionPolicy Bypass -File ./scripts/verify-method-a.ps1",
    "etherscan:get-abi": "node scripts/etherscan-get-abi.js",
    "screen:tokens": "node scripts/token-dead-screen.js",
    "desktop": "electron .",
    "desktop:shortcut": "powershell -NoProfile -ExecutionPolicy Bypass -File ./scripts/create-desktop-shortcut.ps1",
    "desktop:complete": "powershell -NoProfile -ExecutionPolicy Bypass -File ./scripts/complete-desktop.ps1"
  },
  "devDependencies": {
    "@nomicfoundation/hardhat-toolbox": "^5.0.0",
    "dotenv": "^17.4.2",
    "global-agent": "^4.1.3",
    "electron": "^33.4.0",
    "hardhat": "^2.22.0"
  },
  "dependencies": {
    "@openzeppelin/contracts": "^5.0.2",
    "undici": "^6.25.0"
  }
}
